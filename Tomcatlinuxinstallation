##After launching an ec2 seerver with same jenkins SG ##
##installing tomcat service##
cd /tmp
#check the latest tomcat version#
wget https://dlcdn.apache.org/tomcat/tomcat-9/v9.0.118/bin/apache-tomcat-9.0.118.tar.gz
sudo mkdir -p /opt/tomcat
sudo tar -xzvf apache-tomcat-9.0.118.tar.gz -C /opt/tomcat --strip-components=1
sudo chown -R tomcat:tomcat /opt/tomcat
sudo chmod +x /opt/tomcat/bin/*.sh

#start Tomcat with
/opt/tomcat/bin/startup.sh

#Access it at
http://<EC2-public-IP>:8080
